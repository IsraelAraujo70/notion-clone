{
  "expo": {
    "name": "Reason",
    "slug": "reason-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "reason",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "package": "com.israeldeveloper.reason",
      "adaptiveIcon": {
        "backgroundColor": "#F1C232"
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-sqlite"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
